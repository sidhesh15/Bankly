rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - budgets: map (optional) - category -> amount
    //   - createdAt: timestamp (required)
    //
    // Collection: analyses
    // Document ID: {analysisId}
    // Fields:
    //   - uid: string (required)
    //   - fileName: string (required)
    //   - analyzedAt: timestamp (required)
    //   - totalIncome: number (required)
    //   - totalExpenses: number (required)
    //   - transactions: list (required)
    //   - categories: map (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['uid', 'analyzedAt', 'transactions', 'totalIncome', 'totalExpenses']) &&
             data.uid == request.auth.uid &&
             data.transactions is list &&
             data.transactions.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /analyses/{analysisId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidAnalysis(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
